<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FAMILY LOPEZ</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --surface: #111118;
      --border: #ffffff0d;
      --purple: #7b5fff;
      --purple-light: #c9b8ff;
      --text: #e8e8f0;
      --muted: #666;
      --dim: #444;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }

    /* ==========================================
       หน้า ENTER SITE (หน้ากดเข้าเว็บเพื่อเปิดเพลง)
       ========================================== */
    .enter-overlay {
      position: fixed;
      inset: 0;
      background: #060609;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      transition: opacity 0.5s ease, visibility 0.5s ease;
    }
    .enter-overlay.fade-out {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
    .enter-btn {
      background: transparent;
      border: 2px solid var(--purple);
      color: #fff;
      font-family: 'Space Mono', monospace;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 4px;
      padding: 15px 40px;
      border-radius: 30px;
      cursor: pointer;
      box-shadow: 0 0 15px rgba(123,95,255,0.2);
      transition: all 0.3s ease;
      text-transform: uppercase;
    }
    .enter-btn:hover {
      background: var(--purple);
      box-shadow: 0 0 30px rgba(123,95,255,0.6);
      transform: scale(1.05);
    }
    .enter-subtext {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      color: var(--dim);
      margin-top: 15px;
      letter-spacing: 1px;
    }

    /* NAV */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 2rem;
      border-bottom: 1px solid var(--border);
      background: rgba(10,10,15,0.85);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-logo {
      font-family: 'Space Mono', monospace;
      font-size: 16px;
      font-weight: 700;
      color: var(--purple-light);
      letter-spacing: 2px;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 13px;
      letter-spacing: 1px;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--purple-light); }

    /* HERO */
    .hero {
      text-align: center;
      padding: 5rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url('https://scontent.fphs4-1.fna.fbcdn.net/v/t39.30808-6/676590618_1555160719949684_2155220416663153675_n.png?stp=dst-png&cstp=mx2052x800&ctp=s2052x800&_nc_cat=101&ccb=1-7&_nc_sid=cc71e4&_nc_eui2=AeEjILLBKH7oaBwCMI1CHhZblkoIVz0QPtuWSghXPRA-24l8d_9oApteQjCIBh3g04lP4sIuA8Qtet8geuvd2y7k&_nc_ohc=DxSA5fT5tTEQ7kNvwGdUE0r&_nc_oc=AdpKHxzZhEFOUDnz7DpBC6MHmiX2mcd_0nodWODV-ZvPCkwQwfEXWnayyDHLiot93fA&_nc_zt=23&_nc_ht=scontent.fphs4-1.fna&_nc_gid=qZPI_bzgrJDG43TBzVIw-g&_nc_ss=7b2a8&oh=00_Af9BNix7KGq2cMWigKGcjrFWlsCGYWU5GVaguo-l8h-YMw&oe=6A44C760');
      background-size: cover;
      background-position: center;
      opacity: 0.08;
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(108,63,255,0.10) 0%, rgba(10,10,15,0.6) 70%);
      pointer-events: none;
    }
    .hero-tag {
      display: inline-block;
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--purple);
      border: 1px solid rgba(123,95,255,0.35);
      padding: 5px 16px;
      border-radius: 20px;
      margin-bottom: 1.5rem;
      font-family: 'Space Mono', monospace;
      position: relative;
      z-index: 1;
    }
    .hero-title {
      font-size: clamp(3rem, 8vw, 6rem);
      font-weight: 700;
      line-height: 1.0;
      letter-spacing: -2px;
      margin-bottom: 1rem;
      position: relative;
      z-index: 1;
    }
    .hero-title span {
      background: linear-gradient(135deg, var(--purple-light), var(--purple));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* DIVIDER */
    .divider {
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.1), transparent);
      margin: 0 2rem;
    }

    /* SECTION */
    .section {
      padding: 4rem 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }
    .section-title {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 0.5rem;
      letter-spacing: -0.5px;
    }
    .section-desc {
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 1.75rem;
    }

    /* SEARCH */
    .search-wrap { position: relative; margin-bottom: 1rem; }
    .search-wrap svg {
      position: absolute; left: 14px; top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
    }
    .search-wrap input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 16px 12px 42px;
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
    }
    .search-wrap input:focus { border-color: rgba(123,95,255,0.4); }
    .search-wrap input::placeholder { color: #3a3a4a; }
    .result-count {
      font-size: 12px;
      color: #3a3a4a;
      font-family: 'Space Mono', monospace;
      margin-bottom: 1.25rem;
    }

    /* MEMBERS GRID */
    .members-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 10px;
    }
    .member-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.1rem 0.75rem;
      text-align: center;
      transition: border-color 0.2s, transform 0.15s;
    }
    .member-card:hover {
      border-color: rgba(123,95,255,0.4);
      transform: translateY(-2px);
    }
    .member-card.hidden { display: none !important; }

    /* FOUNDER */
    .member-card.founder {
      border-color: rgba(255,199,0,0.45);
      background: linear-gradient(145deg, #111118, #1a1608);
      grid-column: 1 / -1;
    }
    .member-card.founder .member-avatar {
      width: 64px; height: 64px;
      font-size: 20px;
      background: linear-gradient(135deg, #a07800, #ffd000);
      color: #1a1200;
    }
    .member-card.founder .member-name { font-size: 16px; }

    /* LEADER & MEMBER GROUP BOXES */
    .leaders-section {
      grid-column: 1 / -1;
      background: rgba(255,199,0,0.04);
      border: 1px solid rgba(255,199,0,0.15);
      border-radius: 14px;
      padding: 1.25rem;
      margin-bottom: 10px;
    }
    .leaders-section-title {
      font-size: 11px;
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      letter-spacing: 2px;
      color: rgba(255,208,0,0.6);
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .leaders-inner {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 10px;
    }
    .member-card.co-leader {
      border-color: rgba(255,199,0,0.2);
      background: rgba(255,208,0,0.02);
    }
    .member-card.co-leader .member-avatar {
      background: linear-gradient(135deg, #5a4a00, #a07800);
      color: #ffd000;
    }
    .member-card.co-leader:hover { border-color: rgba(255,199,0,0.45); }

    /* BADGE */
    .role-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 10px;
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      letter-spacing: 1.5px;
      padding: 3px 10px;
      border-radius: 20px;
      margin-bottom: 8px;
    }
    .badge-founder {
      color: #ffd000;
      background: rgba(255,208,0,0.12);
      border: 1px solid rgba(255,208,0,0.35);
    }
    .badge-leader {
      color: rgba(255,208,0,0.7);
      background: rgba(255,208,0,0.07);
      border: 1px solid rgba(255,208,0,0.2);
    }
    
    /* AVATAR STYLE */
    .member-avatar {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, #3a2a7a, #6a3fff);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 0.6rem;
      font-size: 14px;
      font-weight: 700;
      color: var(--purple-light);
      font-family: 'Space Mono', monospace;
      overflow: hidden;
      object-fit: cover;
      border: 2px solid rgba(255,255,255,0.05);
    }
    .member-avatar img {
      width: 100%; height: 100%;
      object-fit: cover;
    }
    
    .member-name {
      font-size: 12px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
      line-height: 1.3;
    }
    .fb-btn {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 10px;
      color: var(--purple);
      border: 1px solid rgba(123,95,255,0.25);
      padding: 4px 10px;
      border-radius: 20px;
      text-decoration: none;
      font-family: 'Space Mono', monospace;
      transition: background 0.2s;
    }
    .fb-btn:hover { background: rgba(123,95,255,0.12); }

    /* CONTACT & PARTNERS GRID */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    @media (max-width: 500px) {
      .contact-grid { grid-template-columns: 1fr; }
      .members-grid { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); }
    }
    .social-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      text-decoration: none;
      transition: border-color 0.2s, transform 0.15s;
    }
    .social-card:hover { transform: translateY(-2px); }
    .social-card.fb:hover { border-color: rgba(24,119,242,0.4); }
    .social-card.discord:hover { border-color: rgba(88,101,242,0.4); }
    .social-icon {
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .social-icon.fb { background: rgba(24,119,242,0.12); }
    .social-icon.discord { background: rgba(88,101,242,0.12); }
    .social-info { flex: 1; }
    .social-name { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
    .social-handle { font-size: 11px; color: var(--dim); font-family: 'Space Mono', monospace; }
    .social-arrow { color: #2a2a3a; font-size: 16px; transition: color 0.2s; }
    .social-card:hover .social-arrow { color: var(--purple); }

    /* STATE ANIMATION */
    .loading-state, .error-state {
      text-align: center;
      padding: 2rem;
      color: var(--muted);
      font-family: 'Space Mono', monospace;
      font-size: 14px;
    }

    /* FOOTER */
    footer {
      border-top: 1px solid rgba(255,255,255,0.04);
      padding: 2rem;
      text-align: center;
      font-size: 12px;
      color: #2a2a3a;
      font-family: 'Space Mono', monospace;
      letter-spacing: 1px;
    }
    footer span { color: var(--purple); }
  </style>
</head>
<body>

<div id="youtube-player"></div>

<div class="enter-overlay" id="enterOverlay">
  <button class="enter-btn" onclick="enterSite()">Enter TO MEMBERS SITE</button>
  <div class="enter-subtext">// LOPEZ IM A KILL'EM ALL //</div>
</div>

<nav>
  <div class="nav-logo">FAMILY LOPEZ</div>
  <ul class="nav-links">
    <li><a href="#members">MEMBERS</a></li>
    <li><a href="#contact">CONTACT</a></li>
    <li><a href="#partners">PARTNERS</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-tag">FAMILY LOPEZ</div>
  <h1 class="hero-title">We Are<br><span>LOPEZ</span></h1>
</section>

<div class="divider"></div>

<div class="section" id="members">
  <h2 class="section-title">สมาชิกทั้งหมด</h2>
  <p class="section-desc" id="memberDesc">กำลังโหลดข้อมูลจำนวนสมาชิก...</p>

  <div class="search-wrap">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3a3a4a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" id="searchInput" placeholder="ค้นหาสมาชิก..." oninput="filterMembers()">
  </div>
  <div class="result-count" id="resultCount">กำลังโหลด...</div>

  <div class="members-grid" id="membersGrid">
    <div class="loading-state" style="grid-column: 1/-1;">กำลังโหลดรายชื่อแบบ Real-time...</div>
  </div>
</div>

<div class="divider"></div>

<div class="section" id="contact">
  <h2 class="section-title">ติดต่อเรา</h2>
  <p class="section-desc">ตามหาพวกเราได้ทาง Fanpage และ Discord</p>
  <div class="contact-grid" id="contactContainer">
    <div class="loading-state" style="grid-column: 1/-1;">กำลังโหลดข้อมูลติดต่อ...</div>
  </div>
</div>

<hr style="border: 0; height: 1px; background: rgba(255, 255, 255, 0.08); margin-top: -20px; margin-bottom: 20px;">

<div class="section" id="partners">
  <h2 class="section-title">PARTNERS</h2>
  <p class="section-desc">ดิสคอร์ดพาร์ทเนอร์พันธมิตรของเรา</p>
  <div class="contact-grid" id="partnersContainer">
    <div class="loading-state" style="grid-column: 1/-1;">กำลังโหลดพาร์ทเนอร์...</div>
  </div>
</div>

<footer>
  &copy; 2026 <span>FAMILY LOPEZ</span>. All Rights Reserved.
</footer>

<script>
/* =======================================================
   กำหนดค่าเชื่อมต่อข้อมูลพาร์ทเนอร์และสมาชิก (API Google Sheets)
   ======================================================= */
// เปลี่ยนเป็น URL ของ Google Web App API ของคุณ
const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbz_9eYpY7G65fE86_hA99mK-DInSNoE5m-F3o3g48E3p6r9989Yp-A/exec"; 

let allSearchableMembers = [];

// ฟังก์ชันแปลงตัวแรกเป็นพิมพ์ใหญ่สำหรับทำอวตารกรณีไม่มีรูป
function getInitials(name) {
  return name ? name.charAt(0).toUpperCase() : '?';
}

/* =======================================================
   ระบบ REAL-TIME DATA FETCHING (ดึงข้อมูลอัตโนมัติ)
   ======================================================= */

// 1. ดึงข้อมูลรายชื่อสมาชิก (Real-time)
async function loadMembers() {
  try {
    const response = await fetch(`${SCRIPT_URL}?tab=members`);
    const data = await response.json();
    
    if (!data || data.length === 0) {
      document.getElementById('membersGrid').innerHTML = '<div class="loading-state" style="grid-column:1/-1">ไม่พบข้อมูลสมาชิก</div>';
      return;
    }

    allSearchableMembers = data;
    
    // อัปเดตคำอธิบายจำนวนสมาชิกในหัวข้อหลัก
    document.getElementById('memberDesc').textContent = `${data.length} คนที่เป็นส่วนหนึ่งของ Family Lopez`;
    
    // แสดงผลข้อมูลลง Grid
    renderMembersGrid(data);
    
  } catch (err) {
    console.error(err);
    document.getElementById('membersGrid').innerHTML = `<div class="error-state" style="grid-column:1/-1">&#9888;&#65039; โหลดรายชื่อสมาชิกไม่ได้: ${err.message}</div>`;
  }
}

// ฟังก์ชันสำหรับ Render จัดกลุ่ม Founder, Co-Leader, และ Member
function renderMembersGrid(members) {
  const container = document.getElementById('membersGrid');
  container.innerHTML = '';

  // แยกกลุ่มตำแหน่ง
  const founders = members.filter(m => m.role && m.role.toLowerCase() === 'founder');
  const leaders = members.filter(m => m.role && (m.role.toLowerCase() === 'co-leader' || m.role.toLowerCase() === 'leader'));
  const normalMembers = members.filter(m => !m.role || (m.role.toLowerCase() !== 'founder' && m.role.toLowerCase() !== 'co-leader' && m.role.toLowerCase() !== 'leader'));

  // 1. Render Founder
  founders.forEach(m => {
    container.innerHTML += makeMemberCardHtml(m, 'founder');
  });

  // 2. Render Leaders Section (ถ้ามี)
  if (leaders.length > 0) {
    let leadersHtml = `
      <div class="leaders-section" id="leadersSection">
        <div class="leaders-section-title">ผู้ดูแลประจำแฟมิลี่</div>
        <div class="leaders-inner">
    `;
    leaders.forEach(m => {
      leadersHtml += makeMemberCardHtml(m, 'co-leader');
    });
    leadersHtml += `</div></div>`;
    container.insertAdjacentHTML('beforeend', leadersHtml);
  }

  // 3. Render สมาชิกทั่วไป
  normalMembers.forEach(m => {
    container.innerHTML += makeMemberCardHtml(m, 'member');
  });

  // อัปเดตตัวนับช่องค้นหา
  filterMembers(); 
}

// ฟังก์ชันสร้าง Card HTML ของแต่ละคน
function makeMemberCardHtml(member, typeClass) {
  const avatarContent = member.avatar 
    ? `<img src="${member.avatar}" alt="${member.name}" onerror="this.onerror=null; this.parentNode.innerHTML='${getInitials(member.name)}';">` 
    : getInitials(member.name);

  let badgeHtml = '';
  if (typeClass === 'founder') badgeHtml = '<div class="role-badge badge-founder">&#128081; FOUNDER</div>';
  if (typeClass === 'co-leader') badgeHtml = `<div class="role-badge badge-leader">&#9813; ${member.role.toUpperCase()}</div>`;

  return `
    <div class="member-card ${typeClass}" data-name="${member.name.toLowerCase()}">
      ${badgeHtml}
      <div class="member-avatar">${avatarContent}</div>
      <div class="member-name">${member.name}</div>
      ${member.facebook ? `<a class="fb-btn" href="${member.facebook}" target="_blank" rel="noopener">FACEBOOK</a>` : ''}
    </div>
  `;
}

// 2. ดึงข้อมูล Contacts และ Partners (Real-time)
async function loadSocialTab(tabName, containerId, emptyText) {
  const container = document.getElementById(containerId);
  try {
    const response = await fetch(`${SCRIPT_URL}?tab=${tabName}`);
    const data = await response.json();
    
    if (!data || data.length === 0) {
      container.innerHTML = `<div class="loading-state" style="grid-column:1/-1">${emptyText}</div>`;
      return;
    }

    container.innerHTML = data.map(item => {
      const isDiscord = item.url.includes('discord');
      const cardTypeClass = isDiscord ? 'discord' : 'fb';
      const iconSvg = isDiscord 
        ? `<svg width="20" height="20" viewBox="0 0 24 24" fill="#5865F2"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.031.054a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084-.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>`
        : `<svg width="20" height="20" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`;

      return `
        <a class="social-card ${cardTypeClass}" href="${item.url}" target="_blank" rel="noopener">
          <div class="social-icon ${cardTypeClass}">${iconSvg}</div>
          <div class="social-info">
            <div class="social-name">${item.name}</div>
            <div class="social-handle">${item.handle || item.url}</div>
          </div>
          <div class="social-arrow">&rarr;</div>
        </a>
      `;
    }).join('');

  } catch (err) {
    container.innerHTML = `<div class="error-state" style="grid-column:1/-1">&#9888;&#65039; โหลดข้อมูลสตรีม "${tabName}" ไม่สำเร็จ</div>`;
  }
}

// สั่งดึงข้อมูลทุกแท็บพร้อมกัน
function refreshAllData() {
  loadMembers();
  loadSocialTab('contacts', 'contactContainer', 'ยังไม่มีข้อมูลในแท็บ contacts');
  loadSocialTab('partners', 'partnersContainer', 'ยังไม่มีข้อมูลในแท็บ partners');
}

// ตั้งเวลาให้ดึงข้อมูลใหม่แบบ Real-time ทุกๆ 30 วินาทีอัตโนมัติ (30000ms)
setInterval(refreshAllData, 30000);


/* =======================================================
   ระบบตัวกรองการค้นหาสมาชิก (Search Filter)
   ======================================================= */
function filterMembers() {
  const query = document.getElementById('searchInput').value.toLowerCase().trim();
  const cards = document.querySelectorAll('.member-card');
  let visibleCount = 0;
  let leaderVisible = 0;

  cards.forEach(card => {
    const name = card.dataset.name;
    const isMatch = name.includes(query);
    card.classList.toggle('hidden', !isMatch);
    
    if (isMatch) {
      visibleCount++;
      if (card.parentElement.classList.contains('leaders-inner')) {
        leaderVisible++;
      }
    }
  });

  // ซ่อนกล่องโซนผู้ดูแลระบบทั้งหมด หากค้นหาแล้วไม่เจอในกลุ่มผู้ดูแล
  const leadersSection = document.getElementById('leadersSection');
  if (leadersSection) {
    leadersSection.style.display = leaderVisible === 0 ? 'none' : '';
  }

  document.getElementById('resultCount').textContent = `แสดง ${visibleCount} / ${allSearchableMembers.length} คน`;
}


/* =======================================================
   ระบบเสียงเพลงพื้นหลังอัตโนมัติ (YOUTUBE BACKGROUND MUSIC)
   ======================================================= */
const YOUTUBE_VIDEO_ID = 'wXOdV64bd5VM'; // แก้เป็นไอดีเพลงของคุณตามต้องการ
const MUSIC_VOLUME = 2; 

var tag = document.createElement('script');
tag.src = "https://www.youtube.com/iframe_api";
var firstScriptTag = document.getElementsByTagName('script')[0];
firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

var player;
function onYouTubeIframeAPIReady() {
  player = new YT.Player('youtube-player', {
    height: '0', width: '0',
    videoId: YOUTUBE_VIDEO_ID,
    playerVars: {
      'autoplay': 0, 'controls': 0, 'loop': 1,
      'playlist': YOUTUBE_VIDEO_ID, 'rel': 0
    },
    events: { 'onReady': onPlayerReady }
  });
}

function onPlayerReady(event) {
  event.target.setVolume(MUSIC_VOLUME);
}

// ฟังก์ชันทำงานเมื่อกดปุ่ม Enter
function enterSite() {
  document.getElementById('enterOverlay').classList.add('fade-out');
  
  if (player && typeof player.playVideo === 'function') {
    player.playVideo();
  }
  
  // เรียกข้อมูลครั้งแรกทันทีเมื่อเข้าหน้าเว็บ
  refreshAllData();
}
</script>

